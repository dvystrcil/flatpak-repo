{
  "app-id": "com.megamek.mekhq",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "bin/mekhq",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "mekhq",
      "buildsystem": "simple",
      "build-commands": [
        "curl -L -o mekhq.tar.gz https://github.com/MegaMek/megamek/releases/download/v0.50.12/mekhq-0.50.12.tar.gz",
        "tar -xzf mekhq.tar.gz",
        "cp -r mehq-0.50.12/data mehq/",
        "cp -r mehq-0.50.12/docs mehq/",
        "cp -r mehq-0.50.12/lib mehq/",
        "cp -r mehq-0.50.12/logs mehq/",
        "cp -r mehq-0.50.12/mmconf mehq/",
        "install -Dm755 /app/sources/mekhq-wrapper.sh /app/bin/mekhq",
        "install -Dm644 /app/sources/mekhq.png /app/share/icons/hicolor/256x256/apps/com.megamek.mekhq.png",
        "install -Dm644 /app/sources/com.megamek.mekhq.desktop /app/share/applications/com.megamek.mekhq.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "mekhq-wrapper.sh"
        },
        {
          "type": "file",
          "path": "mekhq.png"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.desktop"
        }
      ]
    }
  ]
}
