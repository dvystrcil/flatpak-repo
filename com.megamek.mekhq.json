{
  "app-id": "com.megamek.mekhq",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "bin/mekhq",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "openjdk-21",
      "module": "org.freedesktop.Java.OpenJDK",
      "version": "21"
    },
    {
      "name": "mekhq",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/mekhq",
        "tar -xzf /app/flatpak_app/sources/mekhq-0.50.12.tar.gz -C /app/mekhq",
        "cp /app/mekhq/mekhq-0.50.12/MegaMek.jar /app/mekhq/",
        "install -D /app/flatpak_app/sources/mekhq-wrapper.sh /app/bin/mekhq",
        "install -D /app/flatpak_app/sources/mekhq.png /app/share/icons/hicolor/256x256/apps/com.megamek.mekhq.png",
        "install -D /app/flatpak_app/sources/com.megamek.mekhq.desktop /app/share/applications/com.megamek.mekhq.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/MegaMek/mekhq/releases/download/v0.50.12/mekhq-0.50.12.tar.gz",
          "sha256": "55edcac0e1b7cf7246d3852f178b8c9f95c302d28fa4001aa2cfba6b9a1256cd",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "mekhq-wrapper.sh",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "mekhq.png",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.desktop",
          "dest": "sources"
        }
      ]
    }
  ]
}