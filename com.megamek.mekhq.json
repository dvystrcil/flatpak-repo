{
  "app-id": "com.megamek.mekhq",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.openjdk21"
  ],
  "command": "mekhq",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-download",
    "--filesystem=/app"
  ],
  "modules": [
    {
      "name": "openjdk",
      "buildsystem": "simple",
      "build-commands": [
        "/usr/lib/sdk/openjdk21/install.sh"
      ]
    },
    {
      "name": "mekhq",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin /app/mekhq",
        "cp -r sources/mekhq-extracted/* /app/mekhq/",
        "rm -f /app/mekhq/*.exe",
        "rm -f /app/mekhq/*.bat",
        "rm -f /app/mekhq/*.l4j.ini",
        "rm -f /app/mekhq/bin/*.bat",
        "rm -f /app/mekhq/SubmitBug.html",
        "sed -i 's|logs/unified_log.log|/home/dan/.local/share/mekhq/logs/unified_log.log|g; s|logs/unified_log_%i.log.gz|/home/dan/.local/share/mekhq/logs/unified_log_%i.log.gz|g; s|logs/error.log|/home/dan/.local/share/mekhq/logs/error.log|g; s|logs/bot_path_ranker.log|/home/dan/.local/share/mekhq/logs/bot_path_ranker.log|g; s|logs/bot_path_ranker_%i.log.gz|/home/dan/.local/share/mekhq/logs/bot_path_ranker_%i.log.gz|g; s|logs/megamek.log|/home/dan/.local/share/mekhq/logs/megamek.log|g; s|logs/megameklab.log|/home/dan/.local/share/mekhq/logs/megameklab.log|g; s|logs/mekhq.log|/home/dan/.local/share/mekhq/logs/mekhq.log|g; s|basePath=\"logs\"|basePath=\"/home/dan/.local/share/mekhq/logs\"|g' /app/mekhq/mmconf/log4j2.xml",
        "chmod +x /app/mekhq/bin/MekHQ /app/mekhq/bin/MegaMek /app/mekhq/bin/MegaMekLab",
        "chmod +x /app/mekhq/MekHQ.sh /app/mekhq/MegaMek.sh /app/mekhq/MegaMekLab.sh",
        "install -Dm755 sources/mekhq-wrapper.sh /app/bin/mekhq",
        "install -Dm644 sources/mekhq.png /app/share/icons/hicolor/256x256/apps/com.megamek.mekhq.png",
        "install -Dm644 sources/com.megamek.mekhq.metainfo.xml /app/share/metainfo/com.megamek.mekhq.metainfo.xml",
        "install -Dm644 sources/com.megamek.mekhq.desktop /app/share/applications/com.megamek.mekhq.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "mekhq-wrapper.sh",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "mekhq.png",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.metainfo.xml",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.desktop",
          "dest": "sources"
        },
        {
          "type": "archive",
          "path": "mekhq.tar.gz",
          "dest": "sources/mekhq-extracted"
        }
      ]
    }
  ]
}
