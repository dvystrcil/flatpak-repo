{
  "app-id": "com.megamek.mekhq",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.openjdk21"
  ],
  "command": "mekhq",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-download",
    "--filesystem=/app"
  ],
  "modules": [
    {
      "name": "openjdk",
      "buildsystem": "simple",
      "build-commands": [
        "/usr/lib/sdk/openjdk21/install.sh"
      ]
    },
    {
      "name": "mekhq",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin /app/mekhq",
        "cp -r sources/mekhq-extracted/* /app/mekhq/",
        "rm -f /app/mekhq/*.exe",
        "rm -f /app/mekhq/*.bat",
        "rm -f /app/mekhq/*.l4j.ini",
        "rm -f /app/mekhq/bin/*.bat",
        "rm -f /app/mekhq/SubmitBug.html",
        "cp /app/mekhq/mmconf/log4j2.xml /app/mekhq/lib/log4j2.xml",
        "cp /app/mekhq/mmconf/milestoneReleases.yml /app/mekhq/lib/milestoneReleases.yml",
        "mkdir -p /tmp/config-classes/META-INF",
        "cp /app/mekhq/lib/log4j2.xml /tmp/config-classes/",
        "cp /app/mekhq/lib/milestoneReleases.yml /tmp/config-classes/",
        "jar cf /app/mekhq/lib/mekhq-config.jar -C /tmp/config-classes .",
        "rm -rf /tmp/config-classes",
        "rm -f /app/mekhq/mmconf/milestoneReleases.yml",
        "sed -i \"s|CLASSPATH=\\$APP_HOME/lib/MekHQ.jar:|CLASSPATH=/app/mekhq/lib/mekhq-config.jar:\\$APP_HOME/lib/MekHQ.jar:|\" /app/mekhq/bin/MekHQ",
        "chmod +x /app/mekhq/bin/MekHQ /app/mekhq/bin/MegaMek /app/mekhq/bin/MegaMekLab",
        "chmod +x /app/mekhq/MekHQ.sh /app/mekhq/MegaMek.sh /app/mekhq/MegaMekLab.sh",
        "install -Dm755 sources/mekhq-wrapper.sh /app/bin/mekhq",
        "install -Dm644 sources/mekhq.png /app/share/icons/hicolor/256x256/apps/com.megamek.mekhq.png",
        "install -Dm644 sources/com.megamek.mekhq.metainfo.xml /app/share/metainfo/com.megamek.mekhq.metainfo.xml",
        "install -Dm644 sources/com.megamek.mekhq.desktop /app/share/applications/com.megamek.mekhq.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "mekhq-wrapper.sh",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "mekhq.png",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.metainfo.xml",
          "dest": "sources"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.desktop",
          "dest": "sources"
        },
        {
          "type": "archive",
          "path": "mekhq.tar.gz",
          "dest": "sources/mekhq-extracted"
        }
      ]
    }
  ]
}
