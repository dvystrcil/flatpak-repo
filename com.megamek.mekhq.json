{
  "app-id": "com.megamek.mekhq",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "bin/mekhq",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "mekhq",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin /app/mekhq/data /app/mekhq/docs /app/mekhq/lib /app/mekhq/logs /app/mekhq/mmconf",
        "cp -r /app/sources/MekHQ-0.50.11/data/* /app/mekhq/data/",
        "cp -r /app/sources/MekHQ-0.50.11/docs/* /app/mekhq/docs/",
        "cp -r /app/sources/MekHQ-0.50.11/lib/* /app/mekhq/lib/",
        "cp -r /app/sources/MekHQ-0.50.11/logs/* /app/mekhq/logs/",
        "cp -r /app/sources/MekHQ-0.50.11/mmconf/* /app/mekhq/mmconf/",
        "install -Dm755 /app/sources/mekhq-wrapper.sh /app/bin/mekhq",
        "install -Dm644 /app/sources/mekhq.png /app/share/icons/hicolor/256x256/apps/com.megamek.mekhq.png",
        "install -Dm644 /app/sources/com.megamek.mekhq.desktop /app/share/applications/com.megamek.mekhq.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "mekhq-wrapper.sh"
        },
        {
          "type": "file",
          "path": "mekhq.png"
        },
        {
          "type": "file",
          "path": "com.megamek.mekhq.desktop"
        },
        {
          "type": "archive",
          "path": "MekHQ-0.50.11.tar.gz"
        }
      ]
    }
  ]
}
